# Принудительный HTTPS + ЧИСТЫЕ URL (без .html)
<IfModule mod_rewrite.c>
  RewriteEngine On

  # http→https через X-Forwarded-Proto (Timeweb за nginx — иначе цикл)
  RewriteCond %{HTTP:X-Forwarded-Proto} =http
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # index.html → / (каталог)
  RewriteCond %{THE_REQUEST} \s/+(([^?\s]+/)?)index\.html[\s?] [NC]
  RewriteRule ^ /%1 [R=301,L]

  # любой /страница.html → /страница (301)
  RewriteCond %{THE_REQUEST} \s/+([^?\s]+?)\.html[\s?] [NC]
  RewriteRule ^ /%1 [R=301,L]

  # внутренне отдаём .html для чистого URL (если такой файл есть)
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{DOCUMENT_ROOT}/$1.html -f
  RewriteRule ^(.+?)/?$ $1.html [L]
</IfModule>

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/xhtml+xml
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/pdf "access plus 1 month"
  ExpiresByType text/javascript "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/svg+xml "access plus 1 year"
  # HTML — не кэшируем: страницы должны обновляться сразу (ассеты бьём через ?v=)
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType application/xml "access plus 1 hour"
  ExpiresDefault "access plus 1 month"
</IfModule>

<IfModule mod_headers.c>
  # HTML всегда ревалидируется на сервере (отдаётся 304, если не менялся) — клиент не залипает на старой версии
  <FilesMatch "\.(?:html|htm)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>

  # --- Защитные заголовки (РКН-аудит S01, 2026-06-16) ---
  # Принудительный HTTPS на год (сайт уже на валидном TLS)
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
  # Запрет встраивания сайта в чужие iframe (clickjacking)
  Header always set X-Frame-Options "SAMEORIGIN"
  # Запрет MIME-sniffing
  Header always set X-Content-Type-Options "nosniff"
  # Не утекать полный URL рефереру на чужие домены
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  # Отключить ненужные браузерные API
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=()"
  # Мягкий CSP: только апгрейд http-подресурсов в https (не ломает inline-скрипты/Метрику/model-viewer)
  Header always set Content-Security-Policy "upgrade-insecure-requests"
</IfModule>

# --- Защита бэкенда CRM (живёт в этом же корне; правила безвредны, даже если CRM нет) ---
Options -Indexes
<FilesMatch "^config\.php$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
  </IfModule>
</FilesMatch>
# Каталог данных/загрузок CRM — закрыт от прямого доступа
RedirectMatch 403 ^/crm-data/.*$
